{
  "name": "@serwist-example/sveltekit-basic",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
  },
  "devDependencies": {
    "@serwist/svelte": "latest",
    "@sveltejs/adapter-static": "3.0.10",
    "@sveltejs/kit": "2.55.0",
    "@sveltejs/vite-plugin-svelte": "7.0.0",
    "serwist": "latest",
    "svelte": "5.55.1",
    "svelte-check": "4.4.6",
    "typescript": "6.0.2",
    "vite": "8.0.3"
  }
}
