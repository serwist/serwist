{
  "name": "rolldown-plugin-serwist",
  "version": "9.5.11",
  "type": "module",
  "description": "A module that integrates Serwist into your Rollup / Rolldown application.",
  "files": [
    "src",
    "dist"
  ],
  "keywords": [
    "react",
    "remix",
    "vue",
    "preact",
    "svelte",
    "sveltekit",
    "solidjs",
    "rolldown",
    "rolldown-plugin",
    "serwist",
    "serwistjs",
    "pwa",
    "sw",
    "service worker",
    "web",
    "service-worker"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "author": "DuCanhGH <ducanh2912.rusty@gmail.com>",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./worker": {
      "types": "./dist/index.worker.d.mts",
      "default": "./dist/index.worker.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rimraf dist && NODE_ENV=production tsdown",
    "dev": "tsdown --watch",
    "lint": "biome lint ./src",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@serwist/build": "workspace:*",
    "serwist": "workspace:*"
  },
  "devDependencies": {
    "@serwist/window": "workspace:*",
    "@types/node": "25.6.0",
    "rolldown": "1.0.0-rc.18",
    "tsdown": "0.21.10",
    "typescript": "6.0.3",
    "vite": "8.0.10"
  },
  "peerDependencies": {
    "rolldown": ">=1.0.0-rc.0",
    "typescript": ">=5.0.0",
    "vite": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "rolldown": {
      "optional": true
    },
    "rollup": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  }
}
