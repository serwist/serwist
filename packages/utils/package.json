{
  "name": "@serwist/utils",
  "version": "9.5.10",
  "type": "module",
  "description": "This module contains utilities used by Serwist packages.",
  "files": [
    "src",
    "dist"
  ],
  "keywords": [
    "serwist",
    "serwistjs",
    "service worker",
    "sw"
  ],
  "author": "Serwist <ducanh2912.rusty@gmail.com> (https://serwist.pages.dev/)",
  "license": "MIT",
  "repository": "https://github.com/serwist/serwist",
  "bugs": "https://github.com/serwist/serwist/issues",
  "homepage": "https://serwist.pages.dev",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rimraf dist && NODE_ENV=production tsdown",
    "dev": "tsdown --watch",
    "lint": "biome lint ./src",
    "typecheck": "tsc"
  },
  "devDependencies": {
    "@types/common-tags": "1.8.4",
    "browserslist": "4.28.2",
    "tsdown": "0.21.10",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "browserslist": ">=4"
  },
  "peerDependenciesMeta": {
    "browserslist": {
      "optional": true
    }
  }
}
